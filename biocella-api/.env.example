# Backend Environment Variables
# Configure these on your private server (web.dcism.org)

# MySQL Database Configuration (from phpMyAdmin)
DB_HOST=localhost
DB_USER=s22102959
DB_PASSWORD=your_mysql_password
DB_NAME=biocella_sql
DB_PORT=3306

# MongoDB Configuration
MONGO_USER=s22102959_BiocellaNoSQL
MONGO_PASSWORD=Teravoid123
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DB=s22102959_BiocellaNoSQL

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS - Your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app

# JWT Secret for token generation
JWT_TOKEN=your-secret-key-here-change-in-production

# Frontend Base URL (for password reset links in emails)
NEXT_PUBLIC_APP_BASE_URL=https://your-app.vercel.app

# Email Configuration (Google OAuth2)
# Get these credentials from Google Cloud Console:
# 1. Create OAuth2 credentials (Client ID & Secret)
# 2. Create refresh token using Google OAuth2 Playground
EMAIL_USER=your-email@gmail.com
EMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
EMAIL_CLIENT_SECRET=your-client-secret
EMAIL_CLIENT_REFRESH_TOKEN=your-refresh-token

