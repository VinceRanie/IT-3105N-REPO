# Backend Environment Variables
# Configure these on your private server (web.dcism.org)

# MySQL Database Configuration (from phpMyAdmin)
DB_HOST=localhost
DB_USER=s22102959
DB_PASSWORD=your_mysql_password
DB_NAME=biocella_sql
DB_PORT=3306

# MongoDB Configuration
MONGO_USER=s22102959_BiocellaNoSQL
MONGO_PASSWORD=Teravoid123
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DB=s22102959_BiocellaNoSQL

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS - Your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app

# JWT Token for authentication
# Generate a secure random string: use `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_TOKEN=generate-a-secure-random-string-here

# Frontend Base URL (for password reset links in emails)
NEXT_PUBLIC_APP_BASE_URL=https://your-app.vercel.app

# Email Configuration - Gmail OAuth2 (for sending emails)
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_USER=your-email@gmail.com

# SMTP Fallback (if Gmail OAuth is unavailable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

